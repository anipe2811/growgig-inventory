# Auto-HTTPS (Let's Encrypt) for the app. SITE_DOMAIN comes from the environment
# (defaults to app.growgig.tech). The DNS A record already points to this VPS.
{$SITE_DOMAIN:app.growgig.tech} {
    encode gzip
    # Once a browser has visited over HTTPS it will never try plain HTTP again
    # (plain :80 on this VPS belongs to the host nginx, which serves a
    # different app and would 404 — see deploy/nginx-app-growgig-redirect.conf).
    header Strict-Transport-Security "max-age=31536000"
    # "inventory-app" is an explicit network alias (see docker-compose.yml).
    # Do NOT proxy to plain "app": another stack on this VPS (gsms) also
    # exposes the DNS name "app" on the shared inventory_web network.
    reverse_proxy inventory-app:80
}
